# =============================================================================
# Local Development Environment Configuration
# =============================================================================
# This file contains all environment variables needed for local development.
# Copy this to .env and modify as needed.
#
# For M1 Mac local testing with Docker:
#   1. Install Docker Desktop for Mac (Apple Silicon)
#   2. Run: npm run dev:start
# =============================================================================

# -----------------------------------------------------------------------------
# Node Environment
# -----------------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Redis Configuration (Local Docker)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Service Ports (Single Source of Truth: shared/constants/service-ports.json)
# -----------------------------------------------------------------------------
COORDINATOR_PORT=3000
P1_ASIA_FAST_PORT=3001
P2_L2_TURBO_PORT=3002
P3_HIGH_VALUE_PORT=3003
P4_SOLANA_PORT=3004
EXECUTION_ENGINE_PORT=3005
CROSS_CHAIN_DETECTOR_PORT=3006
UNIFIED_DETECTOR_PORT=3007

# -----------------------------------------------------------------------------
# Partition Configuration
# -----------------------------------------------------------------------------
# For local testing, use 'asia-fast' partition which includes common chains
PARTITION_ID=asia-fast
INSTANCE_ID=local-dev-1
REGION_ID=local

# -----------------------------------------------------------------------------
# Blockchain RPC Endpoints (Free Public Endpoints) - EVM Chains
# -----------------------------------------------------------------------------
# These are free public endpoints for development/testing.
# For production, use paid providers like Alchemy, Infura, or QuickNode.

# Ethereum Mainnet
ETHEREUM_RPC_URL=https://eth.llamarpc.com
ETHEREUM_WS_URL=wss://ethereum.publicnode.com

# Arbitrum One
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
ARBITRUM_WS_URL=wss://arb1.arbitrum.io/feed

# BSC (Binance Smart Chain)
BSC_RPC_URL=https://bsc-dataseed1.binance.org
BSC_WS_URL=wss://bsc.publicnode.com

# Base
BASE_RPC_URL=https://mainnet.base.org
BASE_WS_URL=wss://base.publicnode.com

# Polygon
POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_WS_URL=wss://polygon-bor-rpc.publicnode.com

# Optimism
OPTIMISM_RPC_URL=https://mainnet.optimism.io
OPTIMISM_WS_URL=wss://optimism.publicnode.com

# Avalanche C-Chain
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc
AVALANCHE_WS_URL=wss://api.avax.network/ext/bc/C/ws

# Fantom
FANTOM_RPC_URL=https://rpc.ftm.tools
FANTOM_WS_URL=wss://fantom.publicnode.com

# zkSync Era
ZKSYNC_RPC_URL=https://mainnet.era.zksync.io
ZKSYNC_WS_URL=wss://mainnet.era.zksync.io/ws

# Linea
LINEA_RPC_URL=https://rpc.linea.build
LINEA_WS_URL=wss://rpc.linea.build

# -----------------------------------------------------------------------------
# Solana Configuration (Optional - for P4 Solana Partition)
# -----------------------------------------------------------------------------
# Solana Mainnet
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# SOLANA_WS_URL=wss://api.mainnet-beta.solana.com

# Solana Devnet (for testing)
# SOLANA_DEVNET_RPC_URL=https://api.devnet.solana.com
# SOLANA_DEVNET_WS_URL=wss://api.devnet.solana.com

# Premium Solana providers (optional, for better performance)
# HELIUS_API_KEY=
# TRITON_API_KEY=

# -----------------------------------------------------------------------------
# Third-Party API Keys (Optional - for enhanced features)
# -----------------------------------------------------------------------------
# Alchemy (for premium RPC access)
# ALCHEMY_API_KEY=
# ALCHEMY_OPTIMISM_KEY=

# Tenderly (for transaction simulation)
# TENDERLY_API_KEY=
# TENDERLY_ACCOUNT_SLUG=
# TENDERLY_PROJECT_SLUG=

# -----------------------------------------------------------------------------
# Price Simulation Mode (For Testing Without Real Blockchain Data)
# -----------------------------------------------------------------------------
# Set to 'true' to use simulated price feeds instead of real blockchain data
# This simulates the DETECTION side - fake prices, fake swap events
SIMULATION_MODE=false
SIMULATION_VOLATILITY=0.02
SIMULATION_UPDATE_INTERVAL_MS=1000
SIMULATION_MIN_PROFIT=50
SIMULATION_TIME_CRITICAL_MS=2000

# -----------------------------------------------------------------------------
# Execution Simulation Mode (For Testing Without Real Transactions)
# -----------------------------------------------------------------------------
# Set to 'true' to bypass blockchain transactions in execution engine
# This simulates the EXECUTION side - no real swaps, fake results
# Useful for testing the full pipeline without risking funds
EXECUTION_SIMULATION_MODE=false
# Simulated success rate (0.0 - 1.0), default 0.85
EXECUTION_SIMULATION_SUCCESS_RATE=0.85
# Simulated execution latency in ms, default 500
EXECUTION_SIMULATION_LATENCY_MS=500
# Simulated gas used per transaction, default 200000
EXECUTION_SIMULATION_GAS_USED=200000
# Gas cost as multiplier of expected profit (0.0 - 1.0), default 0.1
EXECUTION_SIMULATION_GAS_COST_MULTIPLIER=0.1
# Random profit variance (-0.5 to 0.5), randomly varies profit within this range
EXECUTION_SIMULATION_PROFIT_VARIANCE=0.2
# Whether to log simulated executions (true/false)
EXECUTION_SIMULATION_LOG=true

# -----------------------------------------------------------------------------
# Arbitrage Configuration
# -----------------------------------------------------------------------------
MIN_PROFIT_PERCENTAGE=0.003
CONFIDENCE_THRESHOLD=0.75
MAX_GAS_PRICE_GWEI=50

# Cross-chain and triangular arbitrage toggles
CROSS_CHAIN_ENABLED=true
TRIANGULAR_ENABLED=true
MAX_TRIANGULAR_DEPTH=3
OPPORTUNITY_EXPIRY_MS=1000

# -----------------------------------------------------------------------------
# Coordinator Configuration
# -----------------------------------------------------------------------------
# Standby/failover settings
IS_STANDBY=false
CAN_BECOME_LEADER=true
LEADER_LOCK_KEY=coordinator:leader:lock

# Opportunity tracking
MAX_OPPORTUNITIES=1000
OPPORTUNITY_TTL_MS=60000
OPPORTUNITY_CLEANUP_INTERVAL_MS=10000
PAIR_TTL_MS=300000
ALERT_COOLDOWN_MS=300000

# Legacy health polling (disable for Redis Streams mode)
ENABLE_LEGACY_HEALTH_POLLING=false

# -----------------------------------------------------------------------------
# Execution Engine Configuration
# -----------------------------------------------------------------------------
# Timeout settings (in milliseconds)
EXECUTION_TIMEOUT_MS=55000
TRANSACTION_TIMEOUT_MS=50000
SHUTDOWN_TIMEOUT_MS=5000

# Provider health settings
PROVIDER_CONNECTIVITY_TIMEOUT_MS=5000
PROVIDER_HEALTH_CHECK_TIMEOUT_MS=5000
PROVIDER_RECONNECTION_TIMEOUT_MS=10000

# Failover settings
QUEUE_PAUSED_ON_START=false
HEALTH_CHECK_INTERVAL_MS=10000
FAILOVER_THRESHOLD=3
FAILOVER_TIMEOUT_MS=60000
LEADER_HEARTBEAT_INTERVAL_MS=10000
LEADER_LOCK_TTL_MS=30000

# -----------------------------------------------------------------------------
# Circuit Breaker Configuration
# -----------------------------------------------------------------------------
CIRCUIT_BREAKER_ENABLED=true
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_COOLDOWN_MS=300000
CIRCUIT_BREAKER_HALF_OPEN_ATTEMPTS=1

# -----------------------------------------------------------------------------
# MEV Protection (Optional - Disabled by Default)
# -----------------------------------------------------------------------------
MEV_PROTECTION_ENABLED=false
MEV_SUBMISSION_TIMEOUT_MS=30000
MEV_MAX_RETRIES=3
MEV_FALLBACK_TO_PUBLIC=true
MEV_SIMULATE_BEFORE_SUBMIT=true

# MEV Provider Keys (required if MEV_PROTECTION_ENABLED=true)
# FLASHBOTS_AUTH_KEY=
# FLASHBOTS_RELAY_URL=https://relay.flashbots.net
# BLOXROUTE_AUTH_HEADER=
# BLOXROUTE_URL=https://mev.api.blxrbdn.com
# FASTLANE_URL=https://fastlane-rpc.polygon.technology

# -----------------------------------------------------------------------------
# Gas Price Limits per Chain (in Gwei)
# -----------------------------------------------------------------------------
GAS_PRICE_ETHEREUM_GWEI=50
GAS_PRICE_ARBITRUM_GWEI=0.1
GAS_PRICE_OPTIMISM_GWEI=0.001
GAS_PRICE_BASE_GWEI=0.001
GAS_PRICE_POLYGON_GWEI=100
GAS_PRICE_BSC_GWEI=5
GAS_PRICE_AVALANCHE_GWEI=25
GAS_PRICE_FANTOM_GWEI=100
GAS_PRICE_ZKSYNC_GWEI=0.25
GAS_PRICE_LINEA_GWEI=0.5

# -----------------------------------------------------------------------------
# Cross-Region Health (Disable for local development)
# -----------------------------------------------------------------------------
ENABLE_CROSS_REGION_HEALTH=false

# -----------------------------------------------------------------------------
# Alerts & Notifications (Optional)
# -----------------------------------------------------------------------------
# Discord webhook for alerts
# DISCORD_WEBHOOK_URL=

# Slack webhook for alerts
# SLACK_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Authentication & Security (Optional - for API endpoints)
# -----------------------------------------------------------------------------
# JWT_SECRET=your-secret-key-change-in-production
# JWT_EXPIRES_IN=1h
# API_KEYS=key1,key2,key3
# ALLOWED_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Private Keys (ONLY FOR LOCAL TESTING - Never commit real keys!)
# -----------------------------------------------------------------------------
# For local simulation mode, these can be dummy keys.
# Generate test keys: node -e "console.log(require('ethers').Wallet.createRandom().privateKey)"
#
# WARNING: Never use keys with real funds for testing!
# ETHEREUM_PRIVATE_KEY=0x...
# BSC_PRIVATE_KEY=0x...
# ARBITRUM_PRIVATE_KEY=0x...
# BASE_PRIVATE_KEY=0x...
# POLYGON_PRIVATE_KEY=0x...
# OPTIMISM_PRIVATE_KEY=0x...
