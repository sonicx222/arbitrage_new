# =============================================================================
# Local Development Environment Configuration
# =============================================================================
# This file contains all environment variables needed for local development.
# Copy this to .env and modify as needed.
#
# For M1 Mac local testing with Docker:
#   1. Install Docker Desktop for Mac (Apple Silicon)
#   2. Run: npm run dev:start
# =============================================================================

# -----------------------------------------------------------------------------
# Node Environment
# -----------------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Redis Configuration (Local Docker)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Service Ports
# -----------------------------------------------------------------------------
COORDINATOR_PORT=3000
DETECTOR_HEALTH_PORT=3001
CROSS_CHAIN_HEALTH_PORT=3002
EXECUTION_HEALTH_PORT=3003

# -----------------------------------------------------------------------------
# Partition Configuration
# -----------------------------------------------------------------------------
# For local testing, use 'asia-fast' partition which includes common chains
PARTITION_ID=asia-fast
INSTANCE_ID=local-dev-1
REGION_ID=local

# -----------------------------------------------------------------------------
# Blockchain RPC Endpoints (Free Public Endpoints)
# -----------------------------------------------------------------------------
# These are free public endpoints for development/testing.
# For production, use paid providers like Alchemy, Infura, or QuickNode.

# Ethereum Mainnet
ETHEREUM_RPC_URL=https://eth.llamarpc.com
ETHEREUM_WS_URL=wss://ethereum.publicnode.com

# Arbitrum One
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
ARBITRUM_WS_URL=wss://arb1.arbitrum.io/feed

# BSC (Binance Smart Chain)
BSC_RPC_URL=https://bsc-dataseed1.binance.org
BSC_WS_URL=wss://bsc-ws-node.nariox.org:443

# Base
BASE_RPC_URL=https://mainnet.base.org
BASE_WS_URL=wss://base.publicnode.com

# Polygon
POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_WS_URL=wss://polygon-bor.publicnode.com

# Optimism
OPTIMISM_RPC_URL=https://mainnet.optimism.io
OPTIMISM_WS_URL=wss://optimism.publicnode.com

# Avalanche C-Chain
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc
AVALANCHE_WS_URL=wss://api.avax.network/ext/bc/C/ws

# Fantom
FANTOM_RPC_URL=https://rpc.ftm.tools
FANTOM_WS_URL=wss://wsapi.fantom.network

# zkSync Era
ZKSYNC_RPC_URL=https://mainnet.era.zksync.io
ZKSYNC_WS_URL=wss://mainnet.era.zksync.io/ws

# Linea
LINEA_RPC_URL=https://rpc.linea.build
LINEA_WS_URL=wss://rpc.linea.build

# -----------------------------------------------------------------------------
# Simulation Mode (For Testing Without Real Blockchain)
# -----------------------------------------------------------------------------
# Set to 'true' to use simulated price feeds instead of real blockchain data
SIMULATION_MODE=false
SIMULATION_VOLATILITY=0.02
SIMULATION_UPDATE_INTERVAL_MS=1000

# -----------------------------------------------------------------------------
# Arbitrage Configuration
# -----------------------------------------------------------------------------
MIN_PROFIT_PERCENTAGE=0.003
CONFIDENCE_THRESHOLD=0.75
MAX_GAS_PRICE_GWEI=50

# -----------------------------------------------------------------------------
# Cross-Region Health (Disable for local)
# -----------------------------------------------------------------------------
ENABLE_CROSS_REGION_HEALTH=false

# -----------------------------------------------------------------------------
# Private Keys (ONLY FOR LOCAL TESTING - Never commit real keys!)
# -----------------------------------------------------------------------------
# For local simulation mode, these can be dummy keys.
# Generate test keys: node -e "console.log(require('ethers').Wallet.createRandom().privateKey)"
#
# WARNING: Never use keys with real funds for testing!
# ETHEREUM_PRIVATE_KEY=0x...
# BSC_PRIVATE_KEY=0x...
# ARBITRUM_PRIVATE_KEY=0x...
# BASE_PRIVATE_KEY=0x...
# POLYGON_PRIVATE_KEY=0x...
# OPTIMISM_PRIVATE_KEY=0x...
