# Environment Configuration for Local Testing (Anvil Fork)

# --- General ---
NODE_ENV=development
LOG_LEVEL=debug

# --- Redis (Local Docker) ---
REDIS_URL=redis://localhost:6379

# --- Infrastructure ---
# Dashboard port
PORT=3000

# --- Blockchain Providers (Local Anvil Fork) ---
# Pointing all critical chains to your local fork for testing
# NOTE: In a real test, you'd likely fork ONE chain at a time.
# These URLs assume Anvil is running on default port 8545.

# Ethereum (T3)
ETHEREUM_RPC_URL=http://127.0.0.1:8545
ETHEREUM_WS_URL=ws://127.0.0.1:8545

# Arbitrum (T1)
ARBITRUM_RPC_URL=http://127.0.0.1:8545
ARBITRUM_WS_URL=ws://127.0.0.1:8545

# BSC (T1)
BSC_RPC_URL=http://127.0.0.1:8545
BSC_WS_URL=ws://127.0.0.1:8545

# Base (T1)
BASE_RPC_URL=http://127.0.0.1:8545
BASE_WS_URL=ws://127.0.0.1:8545

# Polygon (T2)
POLYGON_RPC_URL=http://127.0.0.1:8545
POLYGON_WS_URL=ws://127.0.0.1:8545

# Optimism (T2)
OPTIMISM_RPC_URL=http://127.0.0.1:8545
OPTIMISM_WS_URL=ws://127.0.0.1:8545

# --- Private Keys (Anvil Default Account 0) ---
# DO NOT USE THESE ON MAINNET. This is Anvil's default test account.
