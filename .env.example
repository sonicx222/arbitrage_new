# =============================================================================
# Environment Configuration Template
# =============================================================================
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env.local
# 2. Fill in your API keys and configuration
# 3. NEVER commit .env or .env.local to git!
#
# For production: Use a secrets manager (AWS Secrets Manager, HashiCorp Vault)
# For CI/CD: Use GitHub Secrets or your CI provider's secret management
# =============================================================================

# -----------------------------------------------------------------------------
# Node Environment
# -----------------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info
# Service identity — used by env-utils.ts to tag log entries and by feature-flags.ts
# to detect execution-engine role for conditional logic. Set per-service in production.
# SERVICE_NAME=arbitrage-coordinator
# SERVICE_ROLE=coordinator
# Log output format: 'json' for structured logs (production), default is pretty-print in development.
# Set to 'json' when shipping logs to Datadog, Loki, CloudWatch, etc.
# LOG_FORMAT=json
# SA-005 FIX: Log sampling for hot-path price-update handler (shared/core/src/partition/handlers.ts).
# LOG_SAMPLE_MAX_PER_SEC caps the max log entries per second (token-bucket); LOG_SAMPLE_RATE is the
# probabilistic pass-through rate (0.0–1.0) for entries beyond the cap.
# LOG_SAMPLE_MAX_PER_SEC=100
# LOG_SAMPLE_RATE=0.01
# P2-4 FIX: Set this in corporate/proxy environments to fix UNABLE_TO_GET_ISSUER_CERT_LOCALLY
# errors for vault-model DEX adapters (Balancer V2, GMX, Beethoven X, Platypus).
# NODE_EXTRA_CA_CERTS=/path/to/corporate-ca-bundle.pem

# P3-2 FIX: Suppress punycode deprecation warning (DEP0040) from upstream dependencies.
# The punycode module is deprecated in Node 22+ but still used by ethers/ws internally.
# NODE_OPTIONS=--disable-warning=DEP0040
# Windows TLS: Corporate proxies inject intermediate CAs that Node.js doesn't trust.
# Without this, all HTTPS/WSS connections to RPC providers fail with UNABLE_TO_GET_LOCAL_ISSUER_CERT.
# For proper fix, use NODE_EXTRA_CA_CERTS=/path/to/corporate-ca.pem instead.
# NODE_TLS_REJECT_UNAUTHORIZED=0

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
# P2-3 FIX: Local dev Redis (npm run dev:redis) has no password by default.
# For production, configure a password in .env.local and update REDIS_URL accordingly.
# Example with password: REDIS_URL=redis://:yourpassword@localhost:6379
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=  # Uncomment and set for production or password-protected Redis
# W2-M10: Set to "true" for self-hosted Redis (unlimited daily commands).
# When false/unset, daily command limit is capped for managed Redis services (e.g., Upstash).
# REDIS_SELF_HOSTED=true
# In-memory Redis mode (for integration tests / CI without a real Redis instance).
# When true, bypasses network and uses in-process emulation. Never use in production.
# REDIS_MEMORY_MODE=false
# SA-002 FIX: Redis reconnection polling interval in partition runner (ms).
# Controls how often partitions retry Redis connection after failure.
# REDIS_RETRY_INTERVAL_MS=30000

# Upstash Redis REST API (alternative to REDIS_URL for serverless/edge deployments).
# Validated by scripts/validate-deployment.ts. Leave blank if using standard Redis.
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# Service Ports
# -----------------------------------------------------------------------------
COORDINATOR_PORT=3000
P1_ASIA_FAST_PORT=3001
P2_L2_TURBO_PORT=3002
P3_HIGH_VALUE_PORT=3003
P4_SOLANA_PORT=3004
# Execution Engine host/port. In Docker Compose, set HOST to the service name.
# In Fly.io, set HOST to execution-engine.internal.
# EXECUTION_ENGINE_HOST=localhost
EXECUTION_ENGINE_PORT=3005
CROSS_CHAIN_DETECTOR_PORT=3006
UNIFIED_DETECTOR_PORT=3007
MEMPOOL_DETECTOR_PORT=3008

# -----------------------------------------------------------------------------
# Mempool Detection (Optional - requires bloXroute BDN access)
# -----------------------------------------------------------------------------
# Run with: npm run dev:mempool or npm run dev:mempool:fast
# Requires BLOXROUTE_AUTH_HEADER (configured in MEV Protection section below)
# Currently supports Ethereum and BSC mempool feeds
# MEMPOOL_DETECTION_ENABLED=false
# BLOXROUTE_WS_ENDPOINT=wss://eth.blxrbdn.com/ws
# BLOXROUTE_BSC_WS_ENDPOINT=wss://bsc.blxrbdn.com/ws
# SA-005 FIX: bloXroute BDN mempool subscription toggle (shared/config/src/mempool-config.ts).
# Set to 'true' to enable live mempool feeds via BLOXROUTE_AUTH_HEADER.
# BLOXROUTE_ENABLED=false
# bloXroute connection settings (defaults match production BDN recommendations)
# BLOXROUTE_CONNECTION_TIMEOUT=10000
# BLOXROUTE_HEARTBEAT_INTERVAL=30000
# BLOXROUTE_RECONNECT_INTERVAL=1000
# BLOXROUTE_MAX_RECONNECT_ATTEMPTS=10
# BLOXROUTE_BACKOFF_MULTIPLIER=2.0
# BLOXROUTE_MAX_RECONNECT_DELAY=60000
# Mempool detector instance identity (auto-generated if not set)
# MEMPOOL_INSTANCE_ID=mempool-detector-1
# Maximum number of pending transactions buffered before oldest are dropped.
# MEMPOOL_MAX_BUFFER_SIZE=10000
# Pending transaction batch size sent to the detector per flush interval.
# MEMPOOL_BATCH_SIZE=100
# Flush interval for batched mempool events in milliseconds.
# MEMPOOL_BATCH_TIMEOUT_MS=50
# Minimum swap size in USD to forward to detector (filters dust transactions).
# MEMPOOL_MIN_SWAP_SIZE_USD=1000
# Comma-separated trader addresses to include (empty = all traders).
# MEMPOOL_INCLUDE_TRADERS=
# Comma-separated router addresses to include (empty = all routers).
# MEMPOOL_INCLUDE_ROUTERS=
# Redis stream key for pending opportunities output (default: stream:pending-opportunities).
# MEMPOOL_PENDING_STREAM=stream:pending-opportunities
# Consumer group name for mempool detector Redis stream reads.
# MEMPOOL_CONSUMER_GROUP=mempool-detector-group
# MAXLEN trim for the pending-opportunities Redis stream.
# MEMPOOL_MAX_STREAM_LENGTH=100000

# -----------------------------------------------------------------------------
# Partition Configuration
# -----------------------------------------------------------------------------
PARTITION_ID=asia-fast
INSTANCE_ID=local-dev-1
REGION_ID=local
# SA-005 FIX: Max concurrent Redis publishes before backpressure kicks in.
# Controls parallel XADD calls from the price-update and opportunity publisher.
# MAX_CONCURRENT_PUBLISHES=100

# =============================================================================
# OpenTelemetry (Centralized Log Aggregation - O-3)
# =============================================================================
# When OTEL_EXPORTER_ENDPOINT is set, all Pino logs are also exported to the
# OTEL collector via OTLP/HTTP. Trace context (traceId, spanId) is injected
# into log records for cross-service correlation.
#
# SETUP:
# 1. Deploy an OTEL collector (e.g., otel/opentelemetry-collector-contrib)
# 2. Set OTEL_EXPORTER_ENDPOINT to the collector's OTLP/HTTP endpoint
# 3. Set OTEL_SERVICE_NAME to identify this service in the collector
#
# OTEL_EXPORTER_ENDPOINT=http://otel-collector:4318
# OTEL_SERVICE_NAME=arbitrage-coordinator
# OTEL_BATCH_SIZE=50
# OTEL_FLUSH_INTERVAL_MS=5000

# =============================================================================
# RPC PROVIDER API KEYS
# =============================================================================
# Sign up for free tiers at each provider and add your keys below.
# See docs/reports/RPC_DEEP_DIVE_ANALYSIS.md for full strategy

# dRPC (https://drpc.org/)
DRPC_API_KEY=

# OnFinality (https://onfinality.io/) - BSC, Polygon, Avalanche, Fantom
ONFINALITY_API_KEY=

# Ankr (https://www.ankr.com/rpc/)
ANKR_API_KEY=

# Infura (https://infura.io/)
INFURA_API_KEY=

# Alchemy (https://www.alchemy.com/)
ALCHEMY_API_KEY=
# Per-chain Alchemy key overrides are not currently used by chain-url-builder.ts.
# Production uses the single ALCHEMY_API_KEY above for all chains.

# Helius - Solana (https://helius.xyz/)
HELIUS_API_KEY=

# Triton - Solana (https://triton.one/)
TRITON_API_KEY=

# Optional providers for extra redundancy (add API keys if using these providers)
# Note: BlastAPI and BlockPI use public endpoints by default; keys only needed for premium tiers

# =============================================================================
# Per-Chain RPC URL Overrides (Optional)
# =============================================================================
# Leave commented to use API key-based URLs (recommended)
# Only uncomment if you need to force a specific endpoint

# ETHEREUM_RPC_URL=
# ETHEREUM_WS_URL=
# ARBITRUM_RPC_URL=
# ARBITRUM_WS_URL=
# BSC_RPC_URL=
# BSC_WS_URL=
# BASE_RPC_URL=
# BASE_WS_URL=
# POLYGON_RPC_URL=
# POLYGON_WS_URL=
# OPTIMISM_RPC_URL=
# OPTIMISM_WS_URL=
# AVALANCHE_RPC_URL=
# AVALANCHE_WS_URL=
# FANTOM_RPC_URL=
# FANTOM_WS_URL=
# ZKSYNC_RPC_URL=
# ZKSYNC_WS_URL=
# LINEA_RPC_URL=
# LINEA_WS_URL=
# SCROLL_RPC_URL=
# SCROLL_WS_URL=
# BLAST_RPC_URL=
# BLAST_WS_URL=
# Mantle and Mode are stubs — uncomment when verified DEX factories are available
# MANTLE_RPC_URL=
# MANTLE_WS_URL=
# MODE_RPC_URL=
# MODE_WS_URL=
# SOLANA_RPC_URL=
# SOLANA_WS_URL=
# SOLANA_DEVNET_RPC_URL=https://api.devnet.solana.com
# Solana devnet WebSocket URL (used when NODE_ENV=development and SOLANA_WS_URL is unset).
# SOLANA_DEVNET_WS_URL=wss://api.devnet.solana.com
# Default USD trade value for Solana opportunity sizing in simulation mode (default: 1000).
# SOLANA_DEFAULT_TRADE_VALUE_USD=1000

# =============================================================================
# Simulation Mode (For Testing)
# =============================================================================
SIMULATION_MODE=true
SIMULATION_VOLATILITY=0.02
# SIMULATION_UPDATE_INTERVAL_MS=5000  # Leave unset to use block-driven simulation (enables swap-events + whale-alerts streams)
# Fraction of simulated swaps that are whale-sized (0.0-0.5, default: 0.05 = 5%)
SIMULATION_WHALE_RATE=0.05
# USD threshold above which a simulated swap emits a 'whaleAlert' event (default: 50000)
# Matches EVENT_CONFIG.swapEvents.whaleThreshold. Increase to reduce whale alert frequency.
# SIMULATION_WHALE_THRESHOLD_USD=50000
SIMULATION_MIN_PROFIT=50
SIMULATION_TIME_CRITICAL_MS=2000
# RT-005 FIX: Multiplier for chain-specific opportunity TTLs in simulation mode.
# At high realism, 130+ opps/s overwhelm the single-threaded coordinator.
# Set to 5-10 to prevent mass expiration. Only affects coordinator; does not
# change detection or execution behavior. Default: 1 (no change).
# SIMULATION_OPPORTUNITY_TTL_MULTIPLIER=5

# Coordinator minimum profit percentage filter. Opportunities with profitPercentage
# below this threshold are rejected before forwarding to execution engine.
# Reduces execution volume from ~88 opps/s to a manageable level.
# Default: 0.1 (0.1% minimum profit). Set to -100 to disable filtering.
# COORDINATOR_MIN_PROFIT_PERCENTAGE=0.1

# Phase 2 (ADR-038): Chain-group execution engine routing.
# When enabled, coordinator routes each opportunity to its chain-group stream instead
# of the single legacy stream. Each EE instance must set EXECUTION_CHAIN_GROUP accordingly.
# Routes: fast (BSC/Polygon/AVAX/FTM), l2 (Arb/Opt/Base/Scroll/Blast),
#         premium (ETH/zkSync/Linea), solana (Solana).
# Default: false (legacy single-EE mode, backward compatible)
# COORDINATOR_CHAIN_GROUP_ROUTING=true

# Phase 2 (ADR-038): Execution engine chain group.
# Set on each EE instance to control which chain-group stream it consumes.
# Valid values: fast | l2 | premium | solana
# Leave unset for legacy single-EE mode (consumes stream:execution-requests).
# EXECUTION_CHAIN_GROUP=fast

# Phase 3 (ADR-039): Async pipeline split.
# When true, a SimulationWorker pre-validates opportunities via BatchQuoterService
# (single eth_call profitability check) and publishes scored results to stream:pre-simulated.
# The EE then consumes from stream:pre-simulated instead of raw exec-request streams.
# Stale pre-simulated opps (older than 2× chain block time) are dropped by the EE.
# Default: false (legacy inline-simulation mode, backward compatible).
# ASYNC_PIPELINE_SPLIT=true

# Execution simulation (no real blockchain transactions)
EXECUTION_SIMULATION_MODE=true
# Testnet execution mode: use simulated prices with real testnet transactions.
# When "true", the execution engine maps mainnet chain names/token addresses to
# testnet equivalents (ethereum->sepolia, etc.), relaxes profit verification
# thresholds, and routes to testnet contract deployments.
# Requires: SIMULATION_MODE=true, EXECUTION_SIMULATION_MODE=false, testnet RPCs.
# TESTNET_EXECUTION_MODE=false
# DANGER: Override to allow simulation mode in production (NODE_ENV=production).
# Without this, the engine throws a CRITICAL error to prevent capital drain.
# SIMULATION_MODE_PRODUCTION_OVERRIDE=true
# Port for local Anvil fork instance (execution-engine/services/simulation/anvil-manager.ts).
# Only relevant when running local Hardhat/Anvil fork for transaction simulation.
# ANVIL_PORT=8546
EXECUTION_SIMULATION_SUCCESS_RATE=0.85
EXECUTION_SIMULATION_LATENCY_MS=500
EXECUTION_SIMULATION_GAS_USED=200000
EXECUTION_SIMULATION_GAS_COST_MULTIPLIER=0.1
EXECUTION_SIMULATION_PROFIT_VARIANCE=0.2
EXECUTION_SIMULATION_LOG=true
# SA-011 FIX: Hybrid execution mode for backrun/uniswapx strategies.
# When "true", strategies can fall back to simulation when live execution fails.
# EXECUTION_HYBRID_MODE=false
# Hybrid execution simulation parameters (used when EXECUTION_HYBRID_MODE=true)
# EXECUTION_HYBRID_SUCCESS_RATE=0.95
# EXECUTION_HYBRID_LATENCY_MS=100
# EXECUTION_HYBRID_GAS_USED=150000
# SIMULATION_REALISM_LEVEL was removed — simulation always uses block-driven model
# with Markov regime transitions, activity tiers, and full strategy coverage.
# Fast-lane opportunity generation rate (0-1). Fraction of ticks that produce
# a high-confidence, high-profit opportunity guaranteed to pass FAST_LANE thresholds.
# Set to 0 to disable. Default: 0.15 (15% of ticks).
# SIMULATION_FAST_LANE_RATE=0.15

# =============================================================================
# Arbitrage Configuration
# =============================================================================
# NOTE: MIN_PROFIT_PERCENTAGE, CONFIDENCE_THRESHOLD, MAX_GAS_PRICE_GWEI were removed
# (orphaned — values hardcoded in thresholds.ts / gas-price-optimizer.ts, not read from env).
# Use COORDINATOR_MIN_PROFIT_PERCENTAGE for coordinator profit filtering.
# Per-chain gas limits are set via GAS_PRICE_{CHAIN}_GWEI below.
CROSS_CHAIN_ENABLED=true
TRIANGULAR_ENABLED=true
# Maximum depth for triangular arbitrage detection (how many hops to search)
# Note: Contracts support up to MAX_SWAP_HOPS=5, but detection limited to 3 for performance
# Increase to 5 if willing to accept higher latency in opportunity detection
MAX_TRIANGULAR_DEPTH=3
OPPORTUNITY_EXPIRY_MS=1000
# Minimum profit threshold for triangular arbitrage paths (0.005 = 0.5% profit).
# Raise to reduce noise from marginal paths; lower to catch more opportunities.
# TRIANGULAR_MIN_PROFIT=0.005
# Maximum wall-clock time for a single triangular arbitrage path search in ms (default: 5000).
# TRIANGULAR_MAX_EXECUTION_TIME_MS=5000
# Estimated gas cost in USD used for EV filtering fallback (default: 15.0).
# Per-chain values in thresholds.ts override this when available.
# ESTIMATED_GAS_COST_USD=15
# Gas price fallback safety factor when EMA-based estimate unavailable (default: 2.0 = 100% safety margin).
# GAS_FALLBACK_SAFETY_FACTOR=2.0
# AMM slippage model parameters (amm-math.ts). Applied when calculating expected output amounts.
# Base slippage (default: 0.003 = 0.3%). Minimum expected slippage on any swap.
# SLIPPAGE_BASE=0.003
# Maximum slippage allowed before rejecting a path (default: 0.10 = 10%).
# SLIPPAGE_MAX=0.10
# Minimum pool liquidity in USD to use dynamic slippage model; below this, use SLIPPAGE_MAX (default: 100000).
# SLIPPAGE_MIN_LIQUIDITY_USD=100000
# Solana: minimum profit threshold for opportunity detection (default: 0.001 SOL).
# MIN_PROFIT_THRESHOLD=0.001

# =============================================================================
# Coordinator Configuration
# =============================================================================
IS_STANDBY=false
CAN_BECOME_LEADER=true
LEADER_LOCK_KEY=coordinator:leader:lock
MAX_OPPORTUNITIES=1000
OPPORTUNITY_TTL_MS=60000
OPPORTUNITY_CLEANUP_INTERVAL_MS=10000
PAIR_TTL_MS=300000
MAX_ACTIVE_PAIRS=10000
ALERT_COOLDOWN_MS=300000
# OP-22: Execution circuit breaker thresholds
EXECUTION_CB_THRESHOLD=5
EXECUTION_CB_RESET_MS=60000
# OP-23: API rate limits (requests per window)
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=100
# P0-1: Trust reverse proxy (Fly.io, nginx) for correct client IP in rate limiting.
# Set to "1" (single hop) for Fly.io. Without this, all clients behind the proxy
# share one rate-limit bucket because Express sees the proxy IP, not client IP.
# TRUST_PROXY=1
# P1-6: Use Redis-backed rate limiting for multi-instance deployments.
# Without this, each instance has its own in-memory rate-limit store, allowing
# N * limit total requests across N instances. Requires REDIS_URL to be set.
# RATE_LIMIT_STORE=redis
# OP-31: Dashboard authentication token (required in production)
# DASHBOARD_AUTH_TOKEN=generate-a-secure-random-string-here
# OP-31: Instance role ('primary' | 'standby')
INSTANCE_ROLE=primary
# Coordinator: fraction of stream MAXLEN at which backpressure kicks in (default: 0.95)
# EXECUTION_STREAM_BACKPRESSURE_RATIO=0.95
# Number of consecutive opportunity expirations before the coordinator logs a warning (default: 10).
# Raise if high-frequency simulation generates many expiry events; lower for more sensitive alerting.
# CONSECUTIVE_EXPIRED_THRESHOLD=10
# Timeout (ms) for Redis operations on /api/redis/stats and /api/redis/dashboard (default: 5000, min: 1000)
# METRICS_REDIS_TIMEOUT_MS=5000
# Timeout (ms) for stream health checks on /api/metrics/prometheus (default: 3000, min: 500)
# METRICS_STREAM_HEALTH_TIMEOUT_MS=3000
# Maximum concurrent SSE dashboard connections (default: 50, min: 1)
# SSE_MAX_CONNECTIONS=50
# SSE push intervals in milliseconds (M-06). Lower = more responsive, higher = less CPU.
# SSE_INTERVAL_METRICS_MS=5000      # System metrics (default: 5000, min: 1000)
# SSE_INTERVAL_SERVICES_MS=5000     # Service health (default: 5000, min: 1000)
# SSE_INTERVAL_STREAMS_MS=10000     # Stream health (default: 10000, min: 2000)
# SSE_INTERVAL_CB_MS=5000           # Circuit breaker (default: 5000, min: 1000)
# SSE_INTERVAL_DIAGNOSTICS_MS=10000 # Diagnostics (default: 10000, min: 2000)
# SSE_INTERVAL_KEEPALIVE_MS=15000   # Keepalive ping (default: 15000, min: 5000)
# SSE_INTERVAL_CEX_SPREAD_MS=10000  # CEX spread data (default: 10000, min: 2000; requires FEATURE_CEX_PRICE_SIGNALS=true)
# Coordinator internal intervals (ARCH-L-05 / P2-15 / P3-10)
# COORDINATOR_METRICS_INTERVAL_MS=5000           # Metrics + backpressure check (default: 5000)
# COORDINATOR_STARVATION_CHECK_INTERVAL_MS=60000 # Pipeline starvation detection (default: 60000)
# COORDINATOR_CLEANUP_INTERVAL_MS=10000          # Cooldown + pair cleanup (default: 10000)
# PROFIT_SANITY_CAP_USD=100000                   # Max single-execution profit before rejection (default: 100000)
# DLQ_TRIM_CUTOFF_MS=3600000                     # DLQ entries older than this are trimmed at startup (default: 3600000 = 1hr)
# ADMISSION_DEPTH_TIERS=0.5:0.7,0.7:0.5,0.85:0.3,0.95:0.1  # Depth ratio → admission budget fraction

# =============================================================================
# Execution Engine Configuration
# =============================================================================
EXECUTION_TIMEOUT_MS=55000
TRANSACTION_TIMEOUT_MS=50000
SHUTDOWN_TIMEOUT_MS=5000
PROVIDER_CONNECTIVITY_TIMEOUT_MS=5000
PROVIDER_HEALTH_CHECK_TIMEOUT_MS=5000
PROVIDER_RECONNECTION_TIMEOUT_MS=10000
# Max concurrent execution slots (global).
# Default: 50 in EXECUTION_SIMULATION_MODE=true, 5 in production.
# RT-N01: EE consumer lag (2291-3165 pending) — set to 20-50 in production to match
# detection throughput (~100 opps/s). For horizontal scaling, enable ADR-038 chain routing
# (COORDINATOR_CHAIN_GROUP_ROUTING + EXECUTION_CHAIN_GROUP) to spread load across EE instances.
# MAX_CONCURRENT_EXECUTIONS=20
# Max concurrent executions per individual chain (0 = no per-chain limit, default: 0)
# MAX_CONCURRENT_PER_CHAIN=0
# Consumer batch size: messages per XREADGROUP call (default: 50, range: 1-100)
# Increase to reduce Redis round-trips at high opportunity inflow rates (130+ opps/s)
# CONSUMER_BATCH_SIZE=50
# Blocking timeout per XREADGROUP call in ms (default: 200, range: 100-10000)
# CONSUMER_BLOCK_MS=200
# Timeout waiting for consumer to ack shutdown before force-termination in ms (default: 5000)
# CONSUMER_SHUTDOWN_ACK_TIMEOUT_MS=5000
# Max age of a pending message before reclaim by another consumer in ms (default: 600000 = 10m)
# CONSUMER_PENDING_MAX_AGE_MS=600000
# Interval to scan and reclaim stale pending messages from crashed consumers in ms (default: 60000 = 1m)
# CONSUMER_STALE_CLEANUP_INTERVAL_MS=60000
QUEUE_PAUSED_ON_START=false
HEALTH_CHECK_INTERVAL_MS=10000
FAILOVER_THRESHOLD=3
FAILOVER_TIMEOUT_MS=60000
LEADER_HEARTBEAT_INTERVAL_MS=10000
LEADER_LOCK_TTL_MS=30000

# Nonce pool pre-allocation for concurrent transaction submission
# Pool maintains a buffer of pre-fetched nonces to avoid sequential RPC calls
# NONCE_POOL_SIZE: Number of nonces to pre-allocate (code default: 5, production recommended: 100)
# NONCE_POOL_REPLENISH_THRESHOLD: Refill when pool drops below this count (code default: 2, production recommended: 20)
NONCE_POOL_SIZE=100
NONCE_POOL_REPLENISH_THRESHOLD=20
# NONCE_MAX_PENDING: Max pending (unconfirmed) transactions per nonce pool (code default: 10, min: 1)
# NONCE_MAX_PENDING=10

# Trade logging — append-only JSONL files for audit trail (persists beyond Redis TTLs)
# Enabled by default; set to 'false' to disable. Daily rotation (trades-YYYY-MM-DD.jsonl).
# TRADE_LOG_ENABLED=true
# TRADE_LOG_DIR=./data/trades
# SA-005-c FIX: Directory for lost-opportunity JSONL dump (default: ./data/lost-opportunities).
# LOST_OPPORTUNITY_DIR=./data/lost-opportunities

# Balance monitoring (execution engine)
# BALANCE_MONITOR_ENABLED=true
# BALANCE_MONITOR_INTERVAL_MS=30000
# BALANCE_MONITOR_LOW_THRESHOLD_ETH=0.01
# Bridge recovery: scan for stuck bridge transactions and retry (default: true).
# Disable to prevent bridge recovery retries if bridge state is stale/corrupt.
# BRIDGE_RECOVERY_ENABLED=true
# BRIDGE_RECOVERY_CHECK_INTERVAL_MS=60000
# BRIDGE_RECOVERY_MAX_CONCURRENT=3
# Execution engine state machine transition timeout in ms (default: 30000).
# Increase on slow RPC nodes to prevent premature TIMEOUT → FAILED transitions.
# STATE_TRANSITION_TIMEOUT_MS=30000
# Time limit for swap transactions to be mined in seconds (default: 300 = 5 min).
# Reduce on fast L2s (Arbitrum: 60); keep high on L1 during gas spikes.
# SWAP_DEADLINE_SECONDS=300
# Grace period to drain in-flight executions during shutdown in ms (default: 30000).
# Must be < SHUTDOWN_TIMEOUT_MS on the process manager level.
# SHUTDOWN_DRAIN_TIMEOUT_MS=30000
# Replace-By-Fee: retry stuck transactions with bumped gas price
# RBF_MAX_RETRIES: Max RBF attempts per transaction (code default: 3, min: 0)
# RBF_GAS_BUMP_PERCENT: Gas price bump per retry in % (code default: 10, min: 1)
# RBF_MAX_RETRIES=3
# RBF_GAS_BUMP_PERCENT=10

# =============================================================================
# RPC Request Batching (Phase 3 Optimization)
# =============================================================================
# Enable JSON-RPC 2.0 batch requests to reduce HTTP overhead
# See RPC_DATA_OPTIMIZATION_IMPLEMENTATION_PLAN.md Phase 3
RPC_BATCHING_ENABLED=false
RPC_BATCH_MAX_SIZE=10
RPC_BATCH_TIMEOUT_MS=10
RPC_BATCH_MAX_QUEUE=100

# =============================================================================
# Circuit Breaker Configuration
# =============================================================================
CIRCUIT_BREAKER_ENABLED=true
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_COOLDOWN_MS=300000
CIRCUIT_BREAKER_HALF_OPEN_ATTEMPTS=1
# API key for circuit breaker POST operations (force open/close).
# Required for authenticated access to /circuit-breaker/open and /circuit-breaker/close endpoints.
# Uses timing-safe comparison. Leave unset to disable circuit breaker API auth.
# CIRCUIT_BREAKER_API_KEY=

# =============================================================================
# MEV PROTECTION CONFIGURATION
# =============================================================================
# Protects arbitrage transactions from front-running and MEV attacks across
# supported chains using chain-appropriate strategies.
#
# CHAINS SUPPORTED:
# - Ethereum: Flashbots/MEV-Share (private relay with rebate capture)
# - BSC: BloXroute (private mempool submission)
# - Polygon: Fastlane (MEV-protected ordering)
# - L2s: Inherent sequencer protection (Arbitrum, Optimism, Base, zkSync, Linea)
#
# See docs/CONFIGURATION.md for detailed setup guide.
# =============================================================================

# Global MEV Protection Toggle
# When disabled, all transactions use public mempool regardless of chain
MEV_PROTECTION_ENABLED=false

# MEV Protection Settings
MEV_SUBMISSION_TIMEOUT_MS=30000    # Timeout for protected submission (30s)
MEV_MAX_RETRIES=3                  # Maximum retry attempts
MEV_FALLBACK_TO_PUBLIC=true        # Fallback to public mempool if private submission fails
MEV_SIMULATE_BEFORE_SUBMIT=true    # Simulate transactions before submission (recommended)

# -----------------------------------------------------------------------------
# Ethereum: Flashbots & MEV-Share Configuration
# -----------------------------------------------------------------------------
# SETUP INSTRUCTIONS:
# 1. Generate a Flashbots auth key (any Ethereum private key):
#    node -e "console.log(require('ethers').Wallet.createRandom().privateKey)"
# 2. Set FLASHBOTS_AUTH_KEY to the generated key
# 3. Enable MEV-Share (FEATURE_MEV_SHARE=true) to capture 50-90% MEV value as rebates
#
# FLASHBOTS_AUTH_KEY=0x1234...your-private-key-here
FLASHBOTS_AUTH_KEY=
FLASHBOTS_RELAY_URL=https://relay.flashbots.net

# MEV-Share: Capture 50-90% of MEV value as rebates (Task 1.1 - Completed)
# When enabled: Uses MEV-Share endpoint with hint configuration
# When disabled: Falls back to standard Flashbots (no rebates)
# Default: true (MEV-Share enabled for value capture)
# @see ADR-028: MEV-Share Integration
# @see docs/architecture/adr/ADR-028-mev-share-integration.md
FEATURE_MEV_SHARE=true
# MEV-Share SSE endpoint URL (default: https://mev-share.flashbots.net).
# Override to use a private or staging MEV-Share relay.
# MEV_SHARE_SSE_ENDPOINT=https://mev-share.flashbots.net

# -----------------------------------------------------------------------------
# BSC: BloXroute Configuration (Task 1.3)
# -----------------------------------------------------------------------------
# SETUP INSTRUCTIONS:
# 1. Sign up at https://bloxroute.com/
# 2. Navigate to your dashboard and copy your authorization header
# 3. Set BLOXROUTE_AUTH_HEADER below
#
# FEATURES:
# - Private mempool submission (prevents front-running on BSC)
# - Automatic fallback to public RPC if BloXroute unavailable
# - Metrics tracking for observability
#
# EXAMPLE:
# BLOXROUTE_AUTH_HEADER=YOUR_BLOXROUTE_AUTH_HEADER_FROM_DASHBOARD
# P2-5 FIX: Commented out empty BLOXROUTE_AUTH_HEADER. When set to empty string,
# FEATURE_ORDERFLOW_PIPELINE emits warnings on every service startup.
# Only uncomment when you have a valid auth header from bloXroute dashboard.
# BLOXROUTE_AUTH_HEADER=
BLOXROUTE_URL=https://mev.api.blxrbdn.com

# -----------------------------------------------------------------------------
# Polygon: Fastlane Configuration (Task 1.3)
# -----------------------------------------------------------------------------
# SETUP INSTRUCTIONS:
# 1. No API key required - uses public Fastlane RPC endpoint
# 2. Enable MEV_PROTECTION_ENABLED=true to activate
#
# FEATURES:
# - MEV-protected transaction ordering on Polygon
# - Priority inclusion through Fastlane RPC
# - Automatic fallback to public RPC if Fastlane unavailable
# - Metrics tracking for observability
#
# NOTE: Fastlane is a public endpoint - no auth header needed
FASTLANE_URL=https://fastlane-rpc.polygon.technology

# -----------------------------------------------------------------------------
# L2 MEV Protection (W2-M15: Undocumented feature flags)
# -----------------------------------------------------------------------------
# Flashbots Protect for L2 chains (Arbitrum, Optimism, Base)
# When enabled, submits transactions via Flashbots Protect L2 RPC endpoints
# Default: false (uses standard L2 sequencer submission)
# FEATURE_FLASHBOTS_PROTECT_L2=false

# Timeboost for Arbitrum (priority ordering via Timeboost auctions)
# When enabled, submits transactions via Arbitrum Timeboost endpoint
# Default: false (uses standard Arbitrum sequencer)
# FEATURE_TIMEBOOST=false

# -----------------------------------------------------------------------------
# Adaptive Risk Scoring (Task 3.2)
# -----------------------------------------------------------------------------
# OVERVIEW:
# Tracks sandwich attacks and dynamically adjusts MEV risk thresholds
# based on historical attack patterns per chain + DEX combination.
#
# BEHAVIOR WHEN ENABLED:
# - Records confirmed sandwich attacks to Redis
# - After 5+ attacks in 24h: Reduces thresholds by 30% (more conservative)
# - Gradually decays back to defaults at 10% per day when attacks stop
# - Uses Redis for storage (free-tier compatible: ~1MB, 10K events max)
#
# SETUP INSTRUCTIONS:
# 1. Enable feature flag: FEATURE_ADAPTIVE_RISK_SCORING=true
# 2. Ensure Redis is running (required for attack tracking)
# 3. Monitor attack patterns via getAllAdjustments() API
#
# STORAGE:
# - Redis keys: adaptive:sandwich_attacks, adaptive:threshold_adjustments:{chain}:{dex}
# - FIFO pruning: Oldest events removed when exceeding maxEvents
# - 7-day retention with automatic cleanup
#
# REFERENCE:
# @see docs/research/FLASHLOAN_MEV_IMPLEMENTATION_PLAN.md Task 3.2
# @see shared/core/src/mev-protection/adaptive-threshold.service.ts
#
FEATURE_ADAPTIVE_RISK_SCORING=true        # Enable adaptive threshold adjustments
ADAPTIVE_ATTACK_THRESHOLD=5               # Attacks needed to trigger adaptation
ADAPTIVE_ACTIVE_WINDOW_HOURS=24           # Time window for counting attacks (hours)
ADAPTIVE_REDUCTION_PERCENT=0.30           # Threshold reduction (30% = 0.30)
ADAPTIVE_DECAY_RATE_PER_DAY=0.10          # Daily decay rate (10% = 0.10)
ADAPTIVE_MAX_EVENTS=10000                 # Max stored events (FIFO pruning)
ADAPTIVE_RETENTION_DAYS=7                 # Event retention period (days)

# -----------------------------------------------------------------------------
# Validation
# -----------------------------------------------------------------------------
# Run validation script to check MEV configuration:
#   npm run validate:mev-setup
#
# The script will verify:
# - Required API keys are configured for each enabled chain
# - URLs are properly formatted
# - Strategy mappings are correct
# =============================================================================

# =============================================================================
# ML / TensorFlow Configuration
# =============================================================================
# TensorFlow.js backend selection for ML models (LSTMPredictor, OrderflowPredictor)
# Backends: cpu (default in dev), wasm (default in prod), tensorflow (native, fastest)
# Note: 'tensorflow' requires @tensorflow/tfjs-node native addon to be installed
# TF_FORCE_BACKEND=cpu

# Enable native TensorFlow backend in production (requires @tensorflow/tfjs-node)
# When true + NODE_ENV=production: Uses 'tensorflow' backend for best performance
# When false + NODE_ENV=production: Uses 'wasm' backend (no native dependency)
# TF_ENABLE_NATIVE=false

# P3-4 FIX: Suppress TensorFlow.js "install our node backend" startup message.
# Set to 2 (warnings) or 3 (errors only) to reduce log noise in dev mode.
# In production, install @tensorflow/tfjs-node for best performance instead.
# TF_CPP_MIN_LOG_LEVEL=2

