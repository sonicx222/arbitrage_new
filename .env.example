# =============================================================================
# Private Keys for Execution (CRITICAL - Use Secrets Manager in Production!)
# =============================================================================
# WARNING: Never store real private keys in .env files!
# For local testing, generate test keys:
#   node -e "console.log(require('ethers').Wallet.createRandom().privateKey)"
#
# For production, use:
#   - AWS Secrets Manager
#   - HashiCorp Vault
#   - Azure Key Vault
#   - Google Secret Manager

# Main trading wallet (required for all execution)
# SECURITY: NEVER commit. Place ONLY in .env.local (gitignored)
# WALLET_PRIVATE_KEY=

# Option A: Per-chain private keys (highest priority — overrides HD derivation)
# Pattern: {CHAIN}_PRIVATE_KEY where CHAIN is uppercase chain name.
# The execution engine reads process.env[`${chainName.toUpperCase()}_PRIVATE_KEY`] dynamically.
# ETHEREUM_PRIVATE_KEY=
# BSC_PRIVATE_KEY=
# ARBITRUM_PRIVATE_KEY=
# BASE_PRIVATE_KEY=
# POLYGON_PRIVATE_KEY=
# OPTIMISM_PRIVATE_KEY=
# AVALANCHE_PRIVATE_KEY=
# FANTOM_PRIVATE_KEY=
# ZKSYNC_PRIVATE_KEY=
# LINEA_PRIVATE_KEY=
# BLAST_PRIVATE_KEY=
# SCROLL_PRIVATE_KEY=

# Solana private key (non-EVM, different key format — base58 encoded)
# Required when FEATURE_SOLANA_EXECUTION=true. Not derivable from WALLET_MNEMONIC.
# SOLANA_PRIVATE_KEY=

# Option B: HD wallet mnemonic (BIP-44 derivation — unique address per chain)
# Derives per-chain wallets using path m/44'/60'/0'/0/{chainIndex}
# Per-chain private keys above override HD derivation for that chain.
# Solana requires explicit SOLANA_PRIVATE_KEY (non-EVM, different key format).
# WALLET_MNEMONIC=
# WALLET_MNEMONIC_PASSPHRASE=

# =============================================================================
# Detection Pipeline Feature Flags (ML, Sizing, Cross-Chain)
# =============================================================================
# P3-23: These flags control detection pipeline behavior.
# All default to false (opt-in). Enable in order of dependency:
# 1. FEATURE_MOMENTUM_TRACKING → 2. FEATURE_ML_SIGNAL_SCORING → 3. FEATURE_SIGNAL_CACHE_READ
# FEATURE_LIQUIDITY_DEPTH_SIZING is independent.

# Enable destination-chain flash loans for cross-chain arbitrage (default: false)
# When enabled: Uses flash loan on dest chain for atomic sell execution (larger positions, price protection)
# When disabled: Uses direct DEX swap on dest chain
# Trade-off: Flash loan fees (~0.09% Aave) vs atomic execution safety
# FEATURE_DEST_CHAIN_FLASH_LOAN=false

# -----------------------------------------------------------------------------
# Flash Loan Contract Addresses (per-chain) — SA-1E-002
# -----------------------------------------------------------------------------
# Used by feature-flags.ts when FEATURE_DEST_CHAIN_FLASH_LOAN=true.
# Pattern: FLASH_LOAN_CONTRACT_{CHAIN} where CHAIN is uppercase chain name.
# Set to the deployed FlashLoanArbitrage contract address on each chain.
# Without these, dest-chain flash loans fall back to direct DEX swaps.
# FLASH_LOAN_CONTRACT_ETHEREUM=0x...
# FLASH_LOAN_CONTRACT_ARBITRUM=0x...
# FLASH_LOAN_CONTRACT_BASE=0x...
# FLASH_LOAN_CONTRACT_POLYGON=0x...
# FLASH_LOAN_CONTRACT_OPTIMISM=0x...
# FLASH_LOAN_CONTRACT_AVALANCHE=0x...
# FLASH_LOAN_CONTRACT_BSC=0x...
# FLASH_LOAN_CONTRACT_FANTOM=0x...
# FLASH_LOAN_CONTRACT_ZKSYNC=0x...
# FLASH_LOAN_CONTRACT_LINEA=0x...
# FLASH_LOAN_CONTRACT_BLAST=0x...
# FLASH_LOAN_CONTRACT_SCROLL=0x...
# FLASH_LOAN_CONTRACT_MANTLE=0x...
# FLASH_LOAN_CONTRACT_MODE=0x...

# -----------------------------------------------------------------------------
# Log Lifecycle Management (LogFileManager)
# -----------------------------------------------------------------------------
# Days to retain trade JSONL logs before deletion (default: 14)
# LOG_RETENTION_DAYS=14
# Max total log directory size in MB before oldest files are compressed (default: 100)
# LOG_MAX_TOTAL_SIZE_MB=100
# Days after which log files are auto-compressed to .gz (default: 1)
# LOG_COMPRESS_AFTER_DAYS=1
# Interval in hours between automatic maintenance runs (default: 6)
# LOG_MAINTENANCE_INTERVAL_HOURS=6

# Enable momentum data recording in detection pipeline (default: false)
# PriceMomentumTracker records price updates from Sync events.
# Prerequisite for FEATURE_ML_SIGNAL_SCORING.
FEATURE_MOMENTUM_TRACKING=true

# Enable background ML signal pre-computation (default: false)
# Background interval (500ms) pre-computes ML-enhanced confidence scores.
# Requires: FEATURE_MOMENTUM_TRACKING=true for fresh input data.
FEATURE_ML_SIGNAL_SCORING=true

# Enable hot-path reading of cached ML signal scores (default: false)
# Filters low-confidence opportunities using pre-computed ML scores.
# Requires: FEATURE_ML_SIGNAL_SCORING=true for fresh cached scores.
FEATURE_SIGNAL_CACHE_READ=true

# Enable liquidity-depth-based optimal trade sizing (default: false)
# LiquidityDepthAnalyzer overrides opportunity.amount with slippage-knee optimal size.
# Independent of ML flags above.
FEATURE_LIQUIDITY_DEPTH_SIZING=true

# =============================================================================
# PHASE 3: MEASUREMENT & DYNAMIC PRICING (Detection Pipeline)
# =============================================================================
# Dynamic L1 fee estimation via on-chain oracle queries
# When enabled, queries ArbGasInfo, OP GasPriceOracle, zks_estimateFee
# to replace static L1_DATA_FEE_USD fallback values
# Default: true (uses !== 'false' pattern — safety-ON). Set to false to disable.
# FEATURE_DYNAMIC_L1_FEES=true
# L1_ORACLE_CACHE_TTL_MS=300000
# L1_ORACLE_REFRESH_INTERVAL_MS=60000

# Orderflow prediction pipeline (default: false)
# Subscribes to stream:pending-opportunities from mempool-detector
# Runs ML predictions and caches for hot-path reads
# Requires: mempool-detector service running (npm run dev:mempool)
# FEATURE_ORDERFLOW_PIPELINE=false
# ORDERFLOW_PREDICTION_CACHE_TTL_MS=30000
# ORDERFLOW_PREDICTION_CACHE_MAX_SIZE=10000
# ORDERFLOW_POLL_INTERVAL_MS=100
# ORDERFLOW_BATCH_SIZE=50

# =============================================================================
# KMS Signing (Phase 2 Item 27)
# =============================================================================
# Enable AWS KMS-based transaction signing (keys never leave HSM)
# Requires: npm install @aws-sdk/client-kms, AWS credentials configured
# KMS key spec: ECC_SECG_P256K1 (secp256k1), usage: SIGN_VERIFY
# FEATURE_KMS_SIGNING=false
#
# Global KMS key ID (ARN, alias, or key ID) — used when per-chain key not set
# KMS_KEY_ID=arn:aws:kms:us-east-1:123456:key/abc-123
#
# Per-chain KMS key IDs (override KMS_KEY_ID for specific chains)
# KMS_KEY_ID_ETHEREUM=
# KMS_KEY_ID_ARBITRUM=
# KMS_KEY_ID_BSC=
# KMS_KEY_ID_BASE=
# KMS_KEY_ID_POLYGON=
# KMS_KEY_ID_OPTIMISM=
# KMS_KEY_ID_AVALANCHE=
# KMS_KEY_ID_FANTOM=
# KMS_KEY_ID_ZKSYNC=
# KMS_KEY_ID_LINEA=
# KMS_KEY_ID_BLAST=
# KMS_KEY_ID_MANTLE=
# KMS_KEY_ID_MODE=
# KMS_KEY_ID_SCROLL=
#
# AWS region for KMS API calls (default: us-east-1)
# AWS_REGION=us-east-1

# =============================================================================
# Monolith Mode Configuration
# =============================================================================
# Health server port for the monolith process (default: 3100)
# MONOLITH_HEALTH_PORT=3100
#
# Graceful shutdown timeout for all workers in ms (default: 30000)
# MONOLITH_SHUTDOWN_TIMEOUT_MS=30000
#
# Redis URL override for monolith mode (defaults to REDIS_URL)
# MONOLITH_REDIS_URL=redis://localhost:6379

# =============================================================================
# Price Matrix Configuration (ADR-005)
# =============================================================================
# Number of token pair slots in the SharedArrayBuffer price matrix (default: 1000)
# Higher values = more pairs tracked, but more memory usage
# PRICE_MATRIX_SLOTS=1000

# Per-partition PriceMatrix sizing override (default: min(L1-derived, 100000))
# Controls SharedArrayBuffer allocation size. Wrong value = OOM or truncated pair coverage.
# Recommended per-partition values:
#   Solana (0 EVM pairs): 1024 | High-value (3 chains, ~420 pairs): 50000
#   L2-turbo (7 chains, ~1400 pairs): 200000 | Asia-fast (4 chains, ~1100 pairs): 150000
# PRICE_MATRIX_MAX_PAIRS=100000

# =============================================================================
# Phase 2 Strategy Feature Flags
# =============================================================================
# Enable backrun strategy for MEV-Share backrunning (default: false)
# When enabled, BackrunStrategy is registered in the strategy factory
FEATURE_BACKRUN_STRATEGY=true
#
# Enable UniswapX filler strategy (default: false)
# When enabled, UniswapXFillerStrategy fills Dutch auction orders
FEATURE_UNISWAPX_FILLER=true
#
# Enable MEV-Share backrun event processing (default: false)
# When enabled, connects to MEV-Share SSE stream for backrun opportunities
# Requires: external Flashbots MEV-Share SSE endpoint
# FEATURE_MEV_SHARE_BACKRUN=false
#
# Strategy threshold overrides (Fix 9)
# BACKRUN_MIN_PROFIT_USD=0.50
# BACKRUN_MAX_GAS_PRICE_GWEI=80
# UNISWAPX_MIN_PROFIT_USD=1.0
# UNISWAPX_MAX_GAS_PRICE_GWEI=50

# =============================================================================
# Phase 3: Solana Execution (Feature-flagged, requires FEATURE_SOLANA_EXECUTION=true)
# =============================================================================
# Enable Solana execution via Jupiter V6 + Jito bundles (default: false)
# @see services/execution-engine/src/strategies/solana-execution.strategy.ts
FEATURE_SOLANA_EXECUTION=false
# SOLANA_RPC_URL=
# SOLANA_WALLET_PUBLIC_KEY=
# JITO_ENDPOINT=
JITO_TIP_LAMPORTS=1000000
# Jito tip account public keys (comma-separated). When set, overrides default tip accounts.
# Obtain from https://jito-labs.gitbook.io/mev/searcher-resources/tip-accounts
# JITO_TIP_ACCOUNTS=
# Jupiter V6 Aggregator API URL for Solana swap routing (default: https://quote-api.jup.ag/v6).
# JUPITER_API_URL=https://quote-api.jup.ag/v6
# JUPITER_TIMEOUT_MS=30000
# JUPITER_MAX_RETRIES=3
# JUPITER_DEFAULT_SLIPPAGE_BPS=50
SOLANA_MAX_SLIPPAGE_BPS=100
# SOLANA_CONFIRMATION_TIMEOUT_MS=60000
# SOLANA_CONFIRMATION_POLL_INTERVAL_MS=500
SOLANA_MIN_PROFIT_LAMPORTS=100000
SOLANA_MAX_PRICE_DEVIATION_PCT=1.0

# =============================================================================
# Phase 3: Statistical Arbitrage (Feature-flagged, requires FEATURE_STATISTICAL_ARB=true)
# =============================================================================
# Enable statistical arbitrage detection and execution (default: false)
# @see shared/core/src/detector/statistical-arbitrage-detector.ts
# @see services/execution-engine/src/strategies/statistical-arbitrage.strategy.ts
FEATURE_STATISTICAL_ARB=true
STAT_ARB_MIN_CONFIDENCE=0.5
STAT_ARB_MAX_AGE_MS=30000
STAT_ARB_MIN_PROFIT_USD=10

# =============================================================================
# Phase 3: CoW Backrun Detection (Feature-flagged, requires FEATURE_COW_BACKRUN=true)
# =============================================================================
# Enable CoW Protocol settlement backrun detection (default: false)
# @see shared/core/src/detector/cow-backrun-detector.ts
FEATURE_COW_BACKRUN=true
# NOTE: COW_BACKRUN_ETH_PRICE_USD removed (orphaned — ethPriceUsd set via constructor config, not env)

# =============================================================================
# CEX Price Signals (ADR-036)
# =============================================================================
# Enable CEX-DEX spread analysis via Binance public trade stream (no API key)
# Provides fair-value reference for opportunity scoring (boost aligned, penalize contradicted)
# In SIMULATION_MODE, synthetic CEX prices are generated from DEX data
FEATURE_CEX_PRICE_SIGNALS=true
# CEX Price Feed (ADR-036) — Resilience tuning
# CEX_WS_MAX_RECONNECT_ATTEMPTS=10    # Max reconnect attempts before degraded mode (default: 10)
# CEX_DEGRADED_PROFIT_MULTIPLIER=1.2  # Min profit multiplier when CEX degraded (default: 1.2, range: 1.0-3.0)
# CEX_PRICE_ALERT_THRESHOLD_PCT=0.3   # Spread alert threshold percentage (default: 0.3)
# CEX_PRICE_MAX_AGE_MS=10000          # Max CEX price age before stale rejection (default: 10000)

# =============================================================================
# Phase 3: Partition Chain Override
# =============================================================================
# Override default partition chains (comma-separated chain IDs)
# When set, only the specified chains are monitored by the partition service
# Example: PARTITION_CHAINS=bsc,polygon,arbitrum
# PARTITION_CHAINS=

# =============================================================================
# Execution Engine: Fast Lane & A/B Testing
# =============================================================================
# Fast lane bypasses queuing for high-confidence, high-profit opportunities
FEATURE_FAST_LANE=true
# FAST_LANE_MIN_CONFIDENCE=0.90
# FAST_LANE_MIN_PROFIT_USD=100
# SA-005-c FIX: Minimum profit percentage for fast-lane qualification (default: 3.0%).
# FAST_LANE_MIN_PROFIT_PCT=3.0
# SA-005-c FIX: Same-chain confidence discount for fast-lane (default: 0.05).
# FAST_LANE_SAME_CHAIN_DISCOUNT=0.05

# SA-005 FIX: Execution engine A/B testing (services/execution-engine/src/engine.ts).
# Compares two execution strategies with statistical significance testing.
AB_TESTING_ENABLED=false
# AB_TESTING_TRAFFIC_SPLIT=0.1       # Fraction of traffic to variant (0.0–1.0)
# AB_TESTING_MIN_SAMPLE_SIZE=100     # Minimum samples before computing significance
# AB_TESTING_SIGNIFICANCE=0.05       # p-value threshold for declaring a winner

# =============================================================================
# R2 Trade Archive (Optional - Cloudflare R2 for long-term trade storage)
# =============================================================================
# When enabled, trades are archived to R2 in addition to local JSONL files
# R2_ENABLED=false
# R2_BUCKET=arbitrage-trades
# R2_ACCOUNT_ID=
# SA-005-a/b FIX: Uncommented so monitoring env-drift check recognizes these as documented.
# SECURITY: Put actual values in .env.local only — never commit secrets.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# R2_ENDPOINT=
# Key prefix for trade log objects stored in R2 (default: 'trades/').
# R2_PREFIX=trades/

# =============================================================================
# Worker Thread Configuration
# =============================================================================
# Set to true when running on memory-constrained instances (reduces worker pool size)
# CONSTRAINED_MEMORY=false
#
# Maximum V8 old-generation heap size (MB) per worker thread (default: 256).
# Workers need enough memory for the SharedArrayBuffer price matrix (524K+ pair slots).
# Reduce to 128 on memory-constrained hosts; increase to 512 if workers OOM.
# WORKER_MAX_OLD_GEN_MB=256
# Number of worker threads in EventProcessingWorkerPool (default: platform-aware 2-4).
# Fly.io single-CPU instances: 2; constrained hosts (512MB): 3; standard (1GB+): 4.
# WORKER_POOL_SIZE=4
# Max pending tasks in worker pool queue before new tasks are rejected (default: platform-aware 300-1000).
# Constrained hosts: 300; standard hosts: 1000.
# WORKER_POOL_MAX_QUEUE_SIZE=1000
# SA-005-c FIX: V8 heap limit for start-local.js process (default: 2048 MB).
# NODE_MAX_OLD_SPACE_SIZE=2048
# SA-005-c FIX: Max memory for in-memory Redis (default: 512 MB). Used by dev:redis:memory script.
# REDIS_MAXMEMORY_MB=512
# Timeout for a single worker thread task in ms (default: 60000 = 1 min).
# Increase if multi-leg path finding on complex chains (Arbitrum, 700+ pairs) times out.
# WORKER_POOL_TASK_TIMEOUT_MS=60000
# L1 price matrix cache size in MB (default: 64). Supports 524K+ pair slots.
# Reduce to 8 on memory-constrained hosts (dev:monitor uses CACHE_L1_SIZE_MB=8).
# CACHE_L1_SIZE_MB=64

# =============================================================================
# Redis Streams: Deduplication & HMAC Compatibility
# =============================================================================
# Dedup fail-closed mode: drop opportunities when Redis dedup is unavailable
# Default: false (fail-open — publish anyway). Set true for high-value trade safety.
DEDUP_FAIL_CLOSED=false


# =============================================================================
# Unified Detector Tuning
# =============================================================================
# Use factory-level WebSocket subscriptions for new pair discovery (default: true).
# When false, uses individual pair subscriptions (higher RPC cost, lower latency).
# USE_FACTORY_SUBSCRIPTIONS=true
# WebSocket ping interval in ms (default: 30000, range: 5000-120000).
# Controls keep-alive frequency for WebSocket connections to RPC providers.
# WS_PING_INTERVAL_MS=30000
# WebSocket reconnect interval in ms (default: 5000, range: 1000-60000).
# Delay between reconnection attempts on WebSocket disconnection.
# WS_RECONNECT_INTERVAL_MS=5000
# WebSocket reconnection parameters (used by chain-instance.ts)
# WS_MAX_RECONNECT_ATTEMPTS=5
# WS_SLOW_RECOVERY_INTERVAL_MS=300000
# SA-011 FIX: WebSocket worker thread parsing (used by websocket-manager.ts).
# When "true", offloads JSON parsing to worker threads. Auto-detected from
# environment (enabled in production), but can be explicitly overridden.
# WS_WORKER_PARSING=true
# Maximum consecutive slow recovery cycles before WebSocket connection is force-reset (default: 10).
# Reduce to 3-5 on unstable RPC providers; raise to 20+ for frequently reconnecting nodes.
# WS_MAX_SLOW_RECOVERY_CYCLES=10
# Event batcher flush timeout in ms (default: 10). Batches swap events before sending to detection.
# Increase to reduce Redis round-trips on high-throughput chains; lower for lower latency.
# EVENT_BATCHER_TIMEOUT_MS=10
# Price batcher max wait before forced flush in ms (default: 10). Controls price-update batching.
# PRICE_BATCHER_MAX_WAIT_MS=10

# ADR-043: Bulkhead Isolation & Health Watchdog (used by chain-instance-manager.ts / handlers.ts)
# CHAIN_WATCHDOG_INTERVAL_MS=30000
# CHAIN_WATCHDOG_MAX_RESTARTS=5
# CHAIN_WATCHDOG_COOLDOWN_MS=120000
# UNHANDLED_REJECTION_THRESHOLD=15

# Reserve cache feature (used by chain-instance.ts for pre-warming reserves)
# RESERVE_CACHE_ENABLED=true
# RESERVE_CACHE_ROLLOUT_PERCENT=0

# =============================================================================
# Multi-Leg Path Finder (shared/core/src/path-finding/multi-leg-path-finder.ts)
# =============================================================================
# Minimum profit threshold to accept a multi-leg arbitrage path (0.001 = 0.1%).
# Raise to reduce noise from marginal paths; lower to catch more opportunities.
# SA-003 FIX: was undocumented
# MULTI_LEG_MIN_PROFIT=0.001

# Maximum candidate DEX pairs evaluated per hop during path search (default: 15).
# Higher values improve path quality at the cost of CPU time.
# SA-003 FIX: was undocumented
# MULTI_LEG_MAX_CANDIDATES=15

# Global path-finding timeout in milliseconds (default: 5000).
# Upper bound applied when no chain-specific timeout matches.
# MULTI_LEG_TIMEOUT_MS=5000

# Per-chain path-finding timeouts (ms). Override MULTI_LEG_TIMEOUT_MS for
# individual chains. Faster chains (L2s) use tighter timeouts to maintain
# sub-50ms detection latency. SA-004 FIX: all were undocumented.
# MULTI_LEG_TIMEOUT_MS_ETHEREUM=5000
# MULTI_LEG_TIMEOUT_MS_BSC=3000
# MULTI_LEG_TIMEOUT_MS_POLYGON=3000
# MULTI_LEG_TIMEOUT_MS_AVALANCHE=3000
# MULTI_LEG_TIMEOUT_MS_FANTOM=3000
# MULTI_LEG_TIMEOUT_MS_ARBITRUM=1500
# MULTI_LEG_TIMEOUT_MS_OPTIMISM=2000
# MULTI_LEG_TIMEOUT_MS_BASE=2000
# MULTI_LEG_TIMEOUT_MS_ZKSYNC=2000
# MULTI_LEG_TIMEOUT_MS_LINEA=2000

# =============================================================================
# Risk Management (Kelly Criterion + Drawdown Circuit Breaker)
# =============================================================================
# See shared/config/src/risk-config.ts for full documentation.
# All opt-out flags default to true (enabled) unless set to 'false'.

# --- Global Toggle ---
# Enable capital risk management globally (default: true).
# RISK_MANAGEMENT_ENABLED=true

# --- Total Capital ---
# Total capital available for trading in wei (REQUIRED for production — drawdown
# breaker computes daily loss % against this value). Default: 10 ETH.
# RISK_TOTAL_CAPITAL=10000000000000000000

# --- Drawdown Circuit Breaker ---
# Enable drawdown-based circuit breaker (default: true).
# DRAWDOWN_BREAKER_ENABLED=true
# Maximum daily loss as fraction of capital before HALT (default: 0.05 = 5%).
# RISK_MAX_DAILY_LOSS=0.05
# Caution threshold — triggers reduced sizing (default: 0.03 = 3%).
# RISK_CAUTION_THRESHOLD=0.03
# Maximum consecutive losses before HALT (default: 5).
# RISK_MAX_CONSECUTIVE_LOSSES=5
# Position size multiplier during RECOVERY state (default: 0.5 = 50%).
# RISK_RECOVERY_MULTIPLIER=0.5
# Consecutive wins required to exit RECOVERY (default: 3).
# RISK_RECOVERY_WINS_REQUIRED=3
# Cooldown before HALT can be reset, in ms (default: 3600000 = 1 hour).
# RISK_HALT_COOLDOWN_MS=3600000
# Position size multiplier during CAUTION state (default: 0.75 = 75%).
# RISK_CAUTION_MULTIPLIER=0.75
# Use rolling 24h window instead of UTC midnight reset for daily PnL.
# When true, drawdown is computed over a sliding 24h window instead of resetting at midnight.
# Default: false (legacy midnight reset).
# RISK_USE_ROLLING_DRAWDOWN=true

# --- Expected Value Calculator ---
# Enable EV-based trade filtering (default: true).
# EV_CALCULATOR_ENABLED=true
# Minimum EV threshold in wei (default: 5000000000000000 = 0.005 ETH).
# RISK_MIN_EV_THRESHOLD=5000000000000000
# Minimum win probability to consider (default: 0.3 = 30%).
# RISK_MIN_WIN_PROBABILITY=0.3
# Maximum loss per trade in wei (default: 100000000000000000 = 0.1 ETH).
# RISK_MAX_LOSS_PER_TRADE=100000000000000000
# Use historical gas costs when estimatedGas unavailable (default: true).
# RISK_USE_HISTORICAL_GAS=true
# Default gas cost in wei when no history (default: 10000000000000000 = 0.01 ETH).
# RISK_DEFAULT_GAS_COST=10000000000000000
# Default profit estimate in wei when no history (default: 20000000000000000 = 0.02 ETH).
# RISK_DEFAULT_PROFIT_ESTIMATE=20000000000000000
# Per-chain minimum EV threshold overrides as JSON (chain → wei string).
# Chains not listed fall back to built-in defaults in ev-calculator.ts.
# Example: {"base":"100000000000000","arbitrum":"300000000000000"}
# RISK_CHAIN_EV_THRESHOLDS=

# --- Position Sizing (Kelly Criterion) ---
# Enable Kelly Criterion position sizing (default: true).
# POSITION_SIZING_ENABLED=true
# Kelly multiplier — 0.5 = half-Kelly (default). Range: 0.01 - 1.0.
# RISK_KELLY_MULTIPLIER=0.5
# Maximum single trade as fraction of capital (default: 0.02 = 2%).
# RISK_MAX_SINGLE_TRADE=0.02
# Minimum trade fraction worth executing (default: 0.001 = 0.1%).
# RISK_MIN_TRADE_FRACTION=0.001
# Gas-budget mode: sizes trades by gas cost instead of Kelly Criterion.
# Use for flash loan arbitrage where only gas fees are at risk (not trade capital).
# Default: false.
# RISK_GAS_BUDGET_MODE=true
# Maximum gas cost per trade in wei (gas-budget mode). Default: 0.05 ETH.
# RISK_MAX_GAS_PER_TRADE=50000000000000000
# Maximum cumulative gas spend per rolling 24h window in wei (gas-budget mode). Default: 1 ETH.
# RISK_DAILY_GAS_BUDGET=1000000000000000000

# --- Execution Risk Controls ---
# Maximum concurrent in-flight trades (default: 3). Limits TOCTOU gap between
# risk assessment and execution completion.
# RISK_MAX_IN_FLIGHT_TRADES=3

# --- Execution Probability Tracker ---
# Minimum samples before returning non-default probability (default: 10).
# RISK_MIN_SAMPLES=10
# Default win probability when insufficient data (default: 0.5).
# Must be >= RISK_MIN_WIN_PROBABILITY or all new combos are rejected.
# RISK_DEFAULT_WIN_PROBABILITY=0.5
# Maximum outcomes stored per key (default: 1000).
# RISK_MAX_OUTCOMES_PER_KEY=1000
# Cleanup interval in ms (default: 3600000 = 1 hour).
# RISK_CLEANUP_INTERVAL_MS=3600000
# Outcome relevance window in ms (default: 604800000 = 7 days).
# RISK_OUTCOME_RELEVANCE_MS=604800000
# Persist outcomes to Redis (default: true).
# RISK_PERSIST_TO_REDIS=true
# Redis key prefix for persistence (default: 'risk:probabilities:').
# RISK_REDIS_KEY_PREFIX=risk:probabilities:

# =============================================================================
# MEV Priority Fee Overrides (Per-Chain)
# =============================================================================
# Override default MEV priority fees without code changes.
# Pattern: MEV_PRIORITY_FEE_{CHAIN}_GWEI=<value>
# Example: MEV_PRIORITY_FEE_ETHEREUM_GWEI=3.0
# See shared/config/src/mev-config.ts for defaults.
# MEV_PRIORITY_FEE_ETHEREUM_GWEI=2.0
# MEV_PRIORITY_FEE_BSC_GWEI=3.0
# MEV_PRIORITY_FEE_POLYGON_GWEI=30.0

# =============================================================================
# External Monitoring Integration (Optional)
# =============================================================================
# Enable external monitoring endpoint pings (uptime monitors, Betterstack, etc.)
# MONITORING_ENABLED=false
# Ping interval in ms (default: 30000 = 30s).
# MONITORING_INTERVAL=30000
# Comma-separated list of monitoring ping endpoints.
# MONITORING_ENDPOINTS=

# =============================================================================
# Async Mutex Tuning
# =============================================================================
# Interval to scan and clean up idle mutex entries in ms (default: 300000 = 5 min).
# MUTEX_CLEANUP_INTERVAL_MS=300000
# Time after last use before a mutex entry is eligible for cleanup in ms (default: 600000 = 10 min).
# MUTEX_IDLE_TTL_MS=600000

# =============================================================================
# Config Validation Overrides (Advanced / Debug)
# =============================================================================
# Disable config validation entirely (DANGEROUS — only for emergency bypass or CI).
# DISABLE_CONFIG_VALIDATION=false
# Skip DEX factory address validation in dex-factories.ts (use in CI without live RPC).
# SKIP_CONFIG_VALIDATION=false
# Strict mode: fail startup on any config warning (default: auto-detected from NODE_ENV).
# STRICT_CONFIG_VALIDATION=false
# SA-005-c FIX: CI / dev escape hatches
# Skip Node.js/npm version check in preinstall hook
# SKIP_PREINSTALL_CHECK=false
# Skip service config validation in scripts/lib/services-config.js
# SKIP_SERVICE_VALIDATION=false
# Skip Redis setup in Jest globalSetup (for unit tests without Redis)
# SKIP_REDIS_SETUP=false
# Enable verbose test debug output in test-utils
# DEBUG_TESTS=false

# =============================================================================
# Platform Detection (Read-Only — set automatically by hosting providers)
# =============================================================================
# These vars are injected by hosting platforms. Do NOT set manually.
# Used by service-config.ts, worker-pool-config.ts, and websocket-manager.ts
# for environment-aware tuning (e.g., pool sizes, reconnect strategies).
# FLY_APP_NAME=                     # Fly.io
# RAILWAY_ENVIRONMENT=              # Railway
# RENDER_SERVICE_NAME=              # Render
# KOYEB_SERVICE_NAME=               # Koyeb
# OCI_RESOURCE_PRINCIPAL_VERSION=   # Oracle Cloud

# =============================================================================
# Self-Healing / PubSub Resilience
# =============================================================================
# Disable PubSub fallback in expert-self-healing-manager.ts (default: false).
# When false, the system falls back to polling when Redis PubSub is unavailable.
# Set true to force polling-only mode (e.g., when Redis PubSub is unreliable).
# DISABLE_PUBSUB_FALLBACK=false
